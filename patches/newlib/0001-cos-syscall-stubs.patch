diff --git a/newlib/libc/sys/cos/sys/dirent.h b/newlib/libc/sys/cos/sys/dirent.h
new file mode 100644
index 000000000..f1c8236d0
--- /dev/null
+++ b/newlib/libc/sys/cos/sys/dirent.h
@@ -0,0 +1,60 @@
+#ifndef _SYS_DIRENT_H
+#define _SYS_DIRENT_H
+
+#include <sys/cdefs.h>
+#include <sys/_types.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#ifndef _SSIZE_T_DECLARED
+typedef _ssize_t ssize_t;
+#define _SSIZE_T_DECLARED
+#endif
+
+#ifndef _INO_T_DECLARED
+typedef __uint64_t ino_t;
+#define _INO_T_DECLARED
+#endif
+
+/* Matches kernel's linux_dirent64 exactly */
+struct dirent {
+    __uint64_t  d_ino;
+    __int64_t   d_off;
+    __uint16_t  d_reclen;
+    __uint8_t   d_type;
+    char        d_name[256];
+};
+
+/* Internal DIR state used by newlib's posix/opendir,readdir,closedir */
+typedef struct {
+    int    dd_fd;
+    long   dd_loc;
+    long   dd_size;
+    char  *dd_buf;
+    int    dd_len;
+    long   dd_seek;
+} DIR;
+
+#define __dirfd(dp) ((dp)->dd_fd)
+
+#define DT_UNKNOWN   0
+#define DT_FIFO      1
+#define DT_CHR       2
+#define DT_DIR       4
+#define DT_BLK       6
+#define DT_REG       8
+#define DT_LNK      10
+#define DT_SOCK     12
+#define DT_WHT      14
+
+#if __BSD_VISIBLE
+#define MAXNAMLEN 255
+#endif
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* _SYS_DIRENT_H */
\ No newline at end of file
