UseTab: Always
TabWidth: 4
IndentWidth: 4
PointerAlignment: Left
SpaceBeforeParens: Always
ColumnLimit: 100
BreakBeforeBraces: Attach
RemoveBracesLLVM: true
AlignConsecutiveMacros: true
AllowShortIfStatementsOnASingleLine: WithoutElse
ReflowComments: true
SortIncludes: true
AlignConsecutiveDeclarations: true
